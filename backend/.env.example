# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── vLLM (cross-ref: /data/www/aimin 11387 health → 127.0.0.1:8001) ──
# From aimin's KB formatter health: {"vllm":"http://127.0.0.1:8001/v1/chat/completions"}
# From aimin's .env.local:          VLLM_API_URL=http://localhost:8000/v1/chat/completions
# Test both ports if unsure; 8001 confirmed via health endpoint
VLLM_BASE_URL=http://127.0.0.1:8001/v1
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct
VLLM_TIMEOUT=30000
VLLM_MAX_TOKENS=1024
VLLM_TEMPERATURE=0.3

# ── RAG Service (existing aimin infra at 8002) ───────────────
# FastAPI + BGE-M3 (1024-dim vectors) + Qdrant
# Endpoints: POST /products/query  POST /products/index  GET /healthz
RAG_SERVICE_URL=http://127.0.0.1:8002
RAG_FOLDER=findingid
RAG_TOP_K=5

# ── MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=findingid
DB_USER=findingid
DB_PASS=your_password_here
DB_POOL_SIZE=20

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ── Jobs ─────────────────────────────────────────────────────
JOB_TTL_SECONDS=300
JOB_POLL_INTERVAL_MS=10000

# ── Security ─────────────────────────────────────────────────
INGEST_API_KEY=findingid-ingest-key-change-this

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://finding.id
